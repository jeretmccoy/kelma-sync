# Docker/local development. Copy to .env; never commit the copy.
KELMA_BIND_ADDRESS=127.0.0.1
KELMA_PORT=8080
POSTGRES_PASSWORD=kelma

# Local auth stores bcrypt password hashes in PostgreSQL and enables open
# registration at POST /v2/auth/register.
KELMA_AUTH_MODE=local

# Native `go run` settings (Compose overrides these inside the container).
PORT=8081
DATABASE_URL=postgres://kelma:kelma@localhost:5433/kelma_sync?sslmode=disable
MIGRATIONS_DIR=./migrations
MEDIA_DIR=media_store

# Optional external account authority; ignored in local auth mode.
# KELMA_IMMERSION_LOGIN_URL=https://accounts.example.com/login

# Optional R2 media storage. The filesystem is used when these are unset.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=

# Optional shared secret for /v2/internal/*; endpoints are disabled when unset.
# KELMA_INTERNAL_SECRET=
