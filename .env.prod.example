# Generic single-host production configuration. Copy to `.env.prod`, replace
# every placeholder, and never commit the resulting file.

KELMA_BIND_ADDRESS=127.0.0.1
KELMA_PORT=8080
POSTGRES_DB=kelma_sync
POSTGRES_USER=kelma
# Generate a URL-safe value, for example: openssl rand -hex 32
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_HEX

# `local` enables open registration. Put public instances behind TLS and rate
# limit /v2/auth/* at the reverse proxy.
KELMA_AUTH_MODE=local

# Optional external account authority (used when auth mode is not `local`).
# KELMA_IMMERSION_LOGIN_URL=https://accounts.example.com/login

# Optional Cloudflare R2 media storage. Leave all four empty to use the
# persistent local media volume.
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# Optional trusted-backend integration. Endpoints are disabled when empty.
KELMA_INTERNAL_SECRET=
